{
    "name": "repo-template-scaffold",
    "version": "0.1.0",
    "private": true,
    "description": "CLI and VS Code scaffolds for creating standard project documents with tab-friendly placeholders.",
    "license": "UNLICENSED",
    "type": "commonjs",
    "bin": {
        "repo-template": "dist/cli.js"
    },
    "scripts": {
        "build": "tsc -p tsconfig.json",
        "dev": "tsc -w -p tsconfig.json",
        "start": "node dist/cli.js",
        "scaffold": "node dist/cli.js",
        "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\""
    },
    "engines": {
        "node": ">=20.0.0"
    },
    "devDependencies": {
        "@types/node": "^22.15.3",
        "typescript": "^5.9.3"
    }
}
